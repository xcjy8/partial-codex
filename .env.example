# Partial Codex - 项目级配置
# 复制此文件为 .env 并填写配置

# API 密钥（必填）
OPENAI_API_KEY=

# 模型提供商（默认：openai）
CODEX_PROVIDER=openai

# 模型名称（默认：codex-mini）
CODEX_MODEL=codex-mini

# API 地址（可选，用于自定义 provider）
# CODEX_BASE_URL=https://your-api-proxy.com/v1

# 审查模型（可选，默认：与主模型相同）
# CODEX_REVIEW_MODEL=gpt-5.5

# 推理力度（可选，默认：high）
# CODEX_REASONING_EFFORT=xhigh

# 上下文窗口大小（可选，默认：1000000）
# CODEX_CONTEXT_WINDOW=1000000

# 自动压缩限制（可选，默认：900000）
# CODEX_AUTO_COMPACT_LIMIT=900000

# 审批策略（可选，默认：never）
# CODEX_APPROVAL_POLICY=never

# 沙箱模式（可选，默认：danger-full-access）
# CODEX_SANDBOX=danger-full-access

# 网络访问（可选，默认：enabled）
# CODEX_NETWORK_ACCESS=enabled

# 额外的 Codex CLI 参数（可选）
# CODEX_EXTRA_ARGS=

# 代理设置（可选）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
