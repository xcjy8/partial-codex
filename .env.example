# Partial Codex - 项目级配置
# 复制此文件为 .env 并填写配置

# API 密钥（必填）
OPENAI_API_KEY=''

# 运行时模型覆盖（可选；config.toml 也会保存初始化时的模型）
CODEX_MODEL='codex-mini'

# 运行时 OpenAI API 地址覆盖（可选，映射到 openai_base_url）
# CODEX_BASE_URL='https://your-api-proxy.com/v1'

# 审查模型（可选，默认：与主模型相同）
# CODEX_REVIEW_MODEL=''

# 推理力度（可选，默认：high）
# CODEX_REASONING_EFFORT='high'

# 上下文窗口大小（可选，默认：1000000）
# CODEX_CONTEXT_WINDOW=1000000

# 自动压缩限制（可选，默认：900000）
# CODEX_AUTO_COMPACT_LIMIT=900000

# 审批策略（可选，默认：never）
# CODEX_APPROVAL_POLICY='never'

# 沙箱模式（可选，默认：workspace-write）
# CODEX_SANDBOX='workspace-write'

# 网络访问（可选；true/false，仅影响 workspace-write 沙箱）
# CODEX_NETWORK_ACCESS=true

# 代理设置（可选）
# HTTP_PROXY='http://127.0.0.1:7890'
# HTTPS_PROXY='http://127.0.0.1:7890'
